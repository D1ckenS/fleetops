# ─────────────────────────────────────────────────────────────────────────────
# FleetOps — Shore API environment variables
# Copy this file to .env (local dev) or .env.production (server) and fill in
# every value marked <REQUIRED>. Values marked [optional] have safe defaults.
# NEVER commit a file that contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# Local dev (docker-compose.dev.yml spins up Postgres on port 5433):
DATABASE_URL="postgresql://fleetops:fleetops_dev@localhost:5433/fleetops_shore"
# Production example:
# DATABASE_URL="postgresql://fleetops:<STRONG_PASSWORD>@localhost:5433/fleetops_shore"

# ── JWT keypair (RS256) ───────────────────────────────────────────────────────
# Generate once with:  pnpm -w run gen:jwt-keys
# Private key signs tokens — never copy to a vessel.
# Public key is distributed to every vessel for offline verification.
JWT_PRIVATE_KEY_PATH=../../keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=../../keys/jwt-public.pem

# Token lifetimes in milliseconds.
JWT_ACCESS_TTL_MS=86400000       # 24 h
JWT_REFRESH_TTL_MS=2592000000    # 30 d

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development             # set to "production" on the server

# ── S3-compatible photo storage (MinIO in dev, any S3-compatible in prod) ─────
# docker-compose.dev.yml runs MinIO on port 9000 with these dev credentials.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=fleetops_minio
S3_SECRET_ACCESS_KEY=fleetops_minio_dev
S3_BUCKET=fleetops-photos
S3_FORCE_PATH_STYLE=1            # required for MinIO; set to 0 for AWS S3
S3_REGION=us-east-1

# ── gRPC Sync gateway ─────────────────────────────────────────────────────────
# Set SYNC_ENABLED=1 to start the gRPC server that vessels connect to.
# Leave unset (or set to 0) for local dev when you don't need sync.
SYNC_ENABLED=0
SYNC_GRPC_PORT=50051
