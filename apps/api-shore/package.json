    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "6.0.0",
    "@types/passport-local": "1.0.38",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2"
  }
