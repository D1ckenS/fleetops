generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN   // platform-level; not tenant-scoped
  TENANT_ADMIN
  PURCHASE_MANAGER
  MASTER        // Captain
  CHIEF_ENGINEER
  OFFICER
  CREW
}

enum JobInstanceStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum RunningHourSource {
  MANUAL
  API
  PLC
}

enum StockMovementType {
  CONSUMPTION  // stock removed (job sign-off, manual)
  RECEIPT      // stock added (GRN)
  ADJUSTMENT   // cycle-count variance (signed quantity)
  TRANSFER_IN  // received from another location
  TRANSFER_OUT // sent to another location
}

enum CertificateSubjectType {
  VESSEL
  COMPONENT
  CREW_MEMBER
}

enum NotificationType {
  CERTIFICATE_EXPIRY
}

enum RequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum RfqStatus {
  DRAFT
  SENT
  CLOSED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DrillStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum WorkPermitStatus {
  REQUESTED
  APPROVED
  ACTIVE
  CLOSED
  CANCELLED
}

enum WorkPermitType {
  HOT_WORK
  CONFINED_SPACE
  WORKING_AT_HEIGHT
  ELECTRICAL_ISOLATION
  COLD_WORK
  DIVING
  OVERSIDE_WORK
}

// ── Tenant ───────────────────────────────────────────────────────────────────
// Root aggregate. Not sync-aware (shore-only master record).

model Tenant {
  id        String    @id @default(cuid())
  name      String
  shortName String?   @map("short_name")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  vessels              Vessel[]
  users                User[]
  masterComponents     MasterComponent[]
  components           Component[]
  jobs                 Job[]
  jobInstances         JobInstance[]
  jobHistories         JobHistory[]
  runningHourReadings  RunningHourReading[]
  partCategories       PartCategory[]
  parts                Part[]
  stockLocations       StockLocation[]
  stockLevels          StockLevel[]
  stockMovements       StockMovement[]
  barcodeBindings      BarcodeBinding[]
  suppliers            Supplier[]
  approvalFlows        ApprovalFlow[]
  approvalSteps        ApprovalStep[]
  requisitions         Requisition[]
  requisitionLines     RequisitionLine[]
  rfqs                 Rfq[]
  quotes               Quote[]
  quoteLines           QuoteLine[]
  purchaseOrders       PurchaseOrder[]
  poLines              POLine[]
  goodsReceipts        GoodsReceipt[]
  goodsReceiptLines    GoodsReceiptLine[]
  certificateTypes     CertificateType[]
  certificates         Certificate[]
  certificateAttachments CertificateAttachment[]
  notifications        Notification[]
  drillTypes           DrillType[]
  drills               Drill[]
  drillRecords         DrillRecord[]
  permitTemplates      PermitTemplate[]
  workPermits          WorkPermit[]
  permitApprovals      PermitApproval[]
  qhseDocuments        QhseDocument[]
  documentRevisions    DocumentRevision[]
  checklistTemplates   ChecklistTemplate[]
  checklistInstances   ChecklistInstance[]
  findings             Finding[]
  capas                Capa[]
  crewMembers          CrewMember[]
  rotations            Rotation[]
  restHourEntries      RestHourEntry[]
  crewCertificates     CrewCertificate[]

  @@map("tenants")
}

// ── Vessel ───────────────────────────────────────────────────────────────────
// Tenant-scoped. RLS applied in migration. Sync-aware (hlc + deletedAt).

model Vessel {
  id        String    @id
  tenantId  String    @map("tenant_id")
  name      String
  imoNumber String?   @map("imo_number")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  users                User[]
  components           Component[]
  jobs                 Job[]
  jobInstances         JobInstance[]
  jobHistories         JobHistory[]
  runningHourReadings  RunningHourReading[]
  stockLocations       StockLocation[]
  stockLevels          StockLevel[]
  stockMovements       StockMovement[]
  requisitions         Requisition[]
  requisitionLines     RequisitionLine[]
  rfqs                 Rfq[]
  quotes               Quote[]
  quoteLines           QuoteLine[]
  purchaseOrders       PurchaseOrder[]
  poLines              POLine[]
  goodsReceipts        GoodsReceipt[]
  goodsReceiptLines    GoodsReceiptLine[]
  certificates         Certificate[]
  certificateAttachments CertificateAttachment[]
  drills               Drill[]
  drillRecords         DrillRecord[]
  workPermits          WorkPermit[]
  permitApprovals      PermitApproval[]
  checklistInstances   ChecklistInstance[]
  findings             Finding[]
  capas                Capa[]
  crewMembers          CrewMember[]
  rotations            Rotation[]
  restHourEntries      RestHourEntry[]
  crewCertificates     CrewCertificate[]

  @@map("vessels")
}

// ── User ─────────────────────────────────────────────────────────────────────
// tenantId is nullable — SUPER_ADMIN users have no tenant assignment.
// A partial unique index (WHERE tenant_id IS NULL) on email prevents duplicate
// super-admin accounts; see migration SQL.

model User {
  id           String    @id
  tenantId     String?   @map("tenant_id")
  vesselId     String?   @map("vessel_id")
  email        String
  username     String?   @map("username")
  passwordHash String?   @map("password_hash")
  role         Role      @default(OFFICER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  hlc          String?
  deletedAt    DateTime? @map("deleted_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  vessel Vessel? @relation(fields: [vesselId], references: [id])

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@map("users")
}

// ── MasterComponent (component template, tenant-scoped, vessel-less) ─────────
// Sharable library entry. Cloning into a Vessel produces a Component whose
// masterId points back here. Later updates may cascade — wired in P1-2.

model MasterComponent {
  id          String  @id
  tenantId    String  @map("tenant_id")
  name        String
  description String?
  sfi         String?
  category    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  components Component[]

  @@index([tenantId])
  @@map("master_components")
}

// ── Component (real onboard equipment) ───────────────────────────────────────
// Hierarchical via parentId self-FK. Carries running-hours counter that drives
// interval-based JobInstance scheduling.

model Component {
  id           String  @id
  tenantId     String  @map("tenant_id")
  vesselId     String  @map("vessel_id")
  parentId     String? @map("parent_id")
  masterId     String? @map("master_id")
  name         String
  description  String?
  sfi          String?
  runningHours Decimal @default(0) @map("running_hours") @db.Decimal(12, 2)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  vessel              Vessel               @relation(fields: [vesselId], references: [id])
  parent              Component?           @relation("ComponentHierarchy", fields: [parentId], references: [id])
  children            Component[]          @relation("ComponentHierarchy")
  master              MasterComponent?     @relation(fields: [masterId], references: [id])
  jobs                Job[]
  jobInstances        JobInstance[]
  jobHistories        JobHistory[]
  runningHourReadings RunningHourReading[]

  @@index([tenantId, vesselId])
  @@index([tenantId, vesselId, parentId])
  @@map("components")
}

// ── Job (maintenance template attached to a Component) ───────────────────────
// Either intervalDays or intervalRunningHours (or both) must be set; the
// scheduler derives the next JobInstance from whichever fires first. The
// not-both-null check is enforced via DB CHECK constraint in the migration.

model Job {
  id                   String      @id
  tenantId             String      @map("tenant_id")
  vesselId             String      @map("vessel_id")
  componentId          String      @map("component_id")
  title                String
  description          String?
  intervalDays         Int?        @map("interval_days")
  intervalRunningHours Decimal?    @map("interval_running_hours") @db.Decimal(12, 2)
  estimatedHours       Decimal?    @map("estimated_hours") @db.Decimal(8, 2)
  priority             JobPriority @default(NORMAL)
  /// JSON array: [{ partId, partName, typicalQuantity, unit }]
  typicalPartsJson     String?     @map("typical_parts_json")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  vessel    Vessel        @relation(fields: [vesselId], references: [id])
  component Component     @relation(fields: [componentId], references: [id])
  instances JobInstance[]
  histories JobHistory[]

  @@index([tenantId, vesselId, componentId])
  @@map("jobs")
}

// ── JobInstance (a scheduled occurrence of a Job) ────────────────────────────
// Lifecycle: PENDING → IN_PROGRESS → DONE | SKIPPED. Sign-off creates the
// matching JobHistory row.

model JobInstance {
  id                String            @id
  tenantId          String            @map("tenant_id")
  vesselId          String            @map("vessel_id")
  jobId             String            @map("job_id")
  componentId       String            @map("component_id")
  status            JobInstanceStatus @default(PENDING)
  dueAt             DateTime?         @map("due_at")
  dueAtRunningHours Decimal?          @map("due_at_running_hours") @db.Decimal(12, 2)
  assignedToUserId  String?           @map("assigned_to_user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  vessel    Vessel       @relation(fields: [vesselId], references: [id])
  job       Job          @relation(fields: [jobId], references: [id])
  component Component    @relation(fields: [componentId], references: [id])
  histories JobHistory[]

  @@index([tenantId, vesselId, status, dueAt])
  @@index([tenantId, vesselId, componentId])
  @@map("job_instances")
}

// ── JobHistory (signed-off, immutable record) ────────────────────────────────
// §9.1: closed records are immutable in the DB. The migration installs a
// BEFORE UPDATE trigger that aborts when any business column would change;
// only sync metadata (deletedAt, hlc, updatedAt) may be written after insert.

model JobHistory {
  id                String   @id
  tenantId          String   @map("tenant_id")
  vesselId          String   @map("vessel_id")
  jobInstanceId     String   @map("job_instance_id")
  jobId             String   @map("job_id")
  componentId       String   @map("component_id")
  completedAt       DateTime @map("completed_at")
  completedByUserId String   @map("completed_by_user_id")
  hoursWorked       Decimal? @map("hours_worked") @db.Decimal(8, 2)
  notes             String?
  signatureHash     String?  @map("signature_hash")
  partsConsumed     Json?    @map("parts_consumed")
  photos            Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  vessel      Vessel      @relation(fields: [vesselId], references: [id])
  jobInstance JobInstance @relation(fields: [jobInstanceId], references: [id])
  job         Job         @relation(fields: [jobId], references: [id])
  component   Component   @relation(fields: [componentId], references: [id])

  @@index([tenantId, vesselId, completedAt])
  @@index([tenantId, vesselId, jobInstanceId])
  @@map("job_histories")
}

// ── RunningHourReading ───────────────────────────────────────────────────────
// Append-only feed of running-hour values per Component. Consumed by the
// scheduler to fire RH-interval Jobs.

model RunningHourReading {
  id               String            @id
  tenantId         String            @map("tenant_id")
  vesselId         String            @map("vessel_id")
  componentId      String            @map("component_id")
  value            Decimal           @db.Decimal(12, 2)
  source           RunningHourSource
  recordedAt       DateTime          @map("recorded_at")
  recordedByUserId String?           @map("recorded_by_user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  vessel    Vessel    @relation(fields: [vesselId], references: [id])
  component Component @relation(fields: [componentId], references: [id])

  @@index([tenantId, vesselId, componentId, recordedAt])
  @@map("running_hour_readings")
}

// ── Inventory (P1-5) ─────────────────────────────────────────────────────────

// PartCategory — hierarchical part classification (fleet-wide, tenant-scoped).
model PartCategory {
  id          String    @id
  tenantId    String    @map("tenant_id")
  parentId    String?   @map("parent_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   PartCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children PartCategory[] @relation("CategoryHierarchy")
  parts    Part[]

  @@index([tenantId])
  @@map("part_categories")
}

// Part — spare-part catalog entry (fleet-wide, tenant-scoped; not vessel-scoped).
model Part {
  id          String    @id
  tenantId    String    @map("tenant_id")
  categoryId  String?   @map("category_id")
  name        String
  description String?
  partNumber  String?   @map("part_number")
  unit        String    @default("pcs")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  category           PartCategory?      @relation(fields: [categoryId], references: [id])
  stockLevels        StockLevel[]
  stockMovements     StockMovement[]
  barcodeBindings    BarcodeBinding[]
  requisitionLines   RequisitionLine[]
  quoteLines         QuoteLine[]
  poLines            POLine[]
  goodsReceiptLines  GoodsReceiptLine[]

  @@index([tenantId])
  @@index([tenantId, partNumber])
  @@map("parts")
}

// StockLocation — named storage location onboard (vessel-scoped).
model StockLocation {
  id          String    @id
  tenantId    String    @map("tenant_id")
  vesselId    String    @map("vessel_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  vessel         Vessel          @relation(fields: [vesselId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  @@index([tenantId, vesselId])
  @@map("stock_locations")
}

// StockLevel — min/max/reorder configuration per Part × StockLocation.
// The ROB quantity is NOT stored here; compute it by SUM(StockMovement.quantity).
model StockLevel {
  id           String   @id
  tenantId     String   @map("tenant_id")
  vesselId     String   @map("vessel_id")
  partId       String   @map("part_id")
  locationId   String   @map("location_id")
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(14, 4)
  maxStock     Decimal? @map("max_stock") @db.Decimal(14, 4)
  reorderPoint Decimal? @map("reorder_point") @db.Decimal(14, 4)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  hlc          String?
  deletedAt    DateTime? @map("deleted_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  vessel   Vessel        @relation(fields: [vesselId], references: [id])
  part     Part          @relation(fields: [partId], references: [id])
  location StockLocation @relation(fields: [locationId], references: [id])

  @@unique([tenantId, vesselId, partId, locationId])
  @@index([tenantId, vesselId])
  @@map("stock_levels")
}

// StockMovement — append-only ledger; ROB = SUM(quantity) per (vessel, part, location).
// Signed quantity: positive = stock added, negative = stock removed.
model StockMovement {
  id               String            @id
  tenantId         String            @map("tenant_id")
  vesselId         String            @map("vessel_id")
  partId           String            @map("part_id")
  locationId       String            @map("location_id")
  movementType     StockMovementType @map("movement_type")
  quantity         Decimal           @db.Decimal(14, 4)
  referenceType    String?           @map("reference_type")
  referenceId      String?           @map("reference_id")
  notes            String?
  recordedByUserId String?           @map("recorded_by_user_id")
  recordedAt       DateTime          @map("recorded_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  hlc              String?
  deletedAt        DateTime? @map("deleted_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  vessel   Vessel        @relation(fields: [vesselId], references: [id])
  part     Part          @relation(fields: [partId], references: [id])
  location StockLocation @relation(fields: [locationId], references: [id])

  @@index([tenantId, vesselId, partId, locationId, recordedAt])
  @@index([tenantId, vesselId, movementType, recordedAt])
  @@map("stock_movements")
}

// BarcodeBinding — maps a barcode string to a Part (for mobile barcode scan).
model BarcodeBinding {
  id              String    @id
  tenantId        String    @map("tenant_id")
  partId          String    @map("part_id")
  barcode         String
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id])

  @@unique([tenantId, barcode])
  @@index([tenantId, partId])
  @@map("barcode_bindings")
}

// ── Purchase (P1-7) ──────────────────────────────────────────────────────────

// Supplier — fleet-wide vendor catalogue (tenant-scoped; no vessel_id).
model Supplier {
  id           String    @id
  tenantId     String    @map("tenant_id")
  name         String
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  address      String?
  country      String?
  notes        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  hlc          String?
  deletedAt    DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  quotes         Quote[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

// ApprovalFlow — named approval policy (tenant-scoped; company-wide).
model ApprovalFlow {
  id          String    @id
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  steps        ApprovalStep[]
  requisitions Requisition[]

  @@index([tenantId])
  @@map("approval_flows")
}

// ApprovalStep — one step in an ApprovalFlow. limitAmount = max a role can approve;
// null means no financial limit for this step.
model ApprovalStep {
  id             String   @id
  tenantId       String   @map("tenant_id")
  flowId         String   @map("flow_id")
  stepOrder      Int      @map("step_order")
  approverRole   Role     @map("approver_role")
  limitAmount    Decimal? @map("limit_amount") @db.Decimal(14, 2)
  limitCurrency  String   @default("USD") @map("limit_currency")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  hlc            String?
  deletedAt      DateTime? @map("deleted_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  flow   ApprovalFlow @relation(fields: [flowId], references: [id])

  @@unique([flowId, stepOrder])
  @@index([tenantId])
  @@map("approval_steps")
}

// Requisition — purchase request raised on a vessel.
// CHECK (status != 'APPROVED' OR approved_by_user_id IS NOT NULL) added in migration.
model Requisition {
  id               String            @id
  tenantId         String            @map("tenant_id")
  vesselId         String            @map("vessel_id")
  title            String
  notes            String?
  status           RequisitionStatus @default(DRAFT)
  totalAmount      Decimal           @default(0) @map("total_amount") @db.Decimal(14, 2)
  currency         String            @default("USD")
  requestedByUserId String?          @map("requested_by_user_id")
  requestedAt      DateTime          @map("requested_at")
  approvalFlowId   String?           @map("approval_flow_id")
  approvedByUserId String?           @map("approved_by_user_id")
  approvedAt       DateTime?         @map("approved_at")
  rejectedByUserId String?           @map("rejected_by_user_id")
  rejectedAt       DateTime?         @map("rejected_at")
  rejectionReason  String?           @map("rejection_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  hlc              String?
  deletedAt        DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  vessel       Vessel        @relation(fields: [vesselId], references: [id])
  approvalFlow ApprovalFlow? @relation(fields: [approvalFlowId], references: [id])
  lines        RequisitionLine[]
  rfqs         Rfq[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, requestedAt])
  @@map("requisitions")
}

// RequisitionLine — one line item within a Requisition.
model RequisitionLine {
  id                  String    @id
  tenantId            String    @map("tenant_id")
  vesselId            String    @map("vessel_id")
  requisitionId       String    @map("requisition_id")
  partId              String?   @map("part_id")
  description         String
  quantity            Decimal   @db.Decimal(14, 4)
  unit                String    @default("pcs")
  estimatedUnitPrice  Decimal?  @map("estimated_unit_price") @db.Decimal(14, 2)
  estimatedTotalPrice Decimal?  @map("estimated_total_price") @db.Decimal(14, 2)
  currency            String?
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  hlc                 String?
  deletedAt           DateTime? @map("deleted_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  vessel      Vessel      @relation(fields: [vesselId], references: [id])
  requisition Requisition @relation(fields: [requisitionId], references: [id])
  part        Part?       @relation(fields: [partId], references: [id])
  poLines     POLine[]

  @@index([tenantId, vesselId, requisitionId])
  @@map("requisition_lines")
}

// Rfq — Request For Quote issued to one or more suppliers for a requisition.
model Rfq {
  id              String    @id
  tenantId        String    @map("tenant_id")
  vesselId        String    @map("vessel_id")
  requisitionId   String?   @map("requisition_id")
  title           String
  notes           String?
  status          RfqStatus @default(DRAFT)
  issuedAt        DateTime? @map("issued_at")
  dueAt           DateTime? @map("due_at")
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  vessel        Vessel        @relation(fields: [vesselId], references: [id])
  requisition   Requisition?  @relation(fields: [requisitionId], references: [id])
  quotes        Quote[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, vesselId, status])
  @@map("rfqs")
}

// Quote — one supplier's response to an Rfq.
model Quote {
  id          String      @id
  tenantId    String      @map("tenant_id")
  vesselId    String      @map("vessel_id")
  rfqId       String      @map("rfq_id")
  supplierId  String      @map("supplier_id")
  validUntil  DateTime?   @map("valid_until")
  totalAmount Decimal     @default(0) @map("total_amount") @db.Decimal(14, 2)
  currency    String      @default("USD")
  notes       String?
  status      QuoteStatus @default(PENDING)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  vessel   Vessel      @relation(fields: [vesselId], references: [id])
  rfq      Rfq         @relation(fields: [rfqId], references: [id])
  supplier Supplier    @relation(fields: [supplierId], references: [id])
  lines    QuoteLine[]

  @@index([tenantId, vesselId, rfqId])
  @@map("quotes")
}

// QuoteLine — one line item in a Quote (mirrors a requisition line).
model QuoteLine {
  id          String    @id
  tenantId    String    @map("tenant_id")
  vesselId    String    @map("vessel_id")
  quoteId     String    @map("quote_id")
  partId      String?   @map("part_id")
  description String
  quantity    Decimal   @db.Decimal(14, 4)
  unit        String    @default("pcs")
  unitPrice   Decimal   @map("unit_price") @db.Decimal(14, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(14, 2)
  currency    String    @default("USD")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vessel Vessel @relation(fields: [vesselId], references: [id])
  quote  Quote  @relation(fields: [quoteId], references: [id])
  part   Part?  @relation(fields: [partId], references: [id])

  @@index([tenantId, vesselId, quoteId])
  @@map("quote_lines")
}

// PurchaseOrder — formal order sent to a supplier.
// CHECK (status = 'DRAFT' OR supplier_id IS NOT NULL) added in migration.
model PurchaseOrder {
  id                 String              @id
  tenantId           String              @map("tenant_id")
  vesselId           String              @map("vessel_id")
  requisitionId      String?             @map("requisition_id")
  rfqId              String?             @map("rfq_id")
  supplierId         String?             @map("supplier_id")
  poNumber           String?             @map("po_number")
  title              String
  notes              String?
  status             PurchaseOrderStatus @default(DRAFT)
  totalAmount        Decimal             @default(0) @map("total_amount") @db.Decimal(14, 2)
  currency           String              @default("USD")
  orderedByUserId    String?             @map("ordered_by_user_id")
  orderedAt          DateTime?           @map("ordered_at")
  expectedDeliveryAt DateTime?           @map("expected_delivery_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  hlc                String?
  deletedAt          DateTime? @map("deleted_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  vessel      Vessel         @relation(fields: [vesselId], references: [id])
  requisition Requisition?   @relation(fields: [requisitionId], references: [id])
  rfq         Rfq?           @relation(fields: [rfqId], references: [id])
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  lines       POLine[]
  receipts    GoodsReceipt[]

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, supplierId])
  @@map("purchase_orders")
}

// POLine — one line item in a PurchaseOrder.
model POLine {
  id               String    @id
  tenantId         String    @map("tenant_id")
  vesselId         String    @map("vessel_id")
  poId             String    @map("po_id")
  partId           String?   @map("part_id")
  description      String
  quantity         Decimal   @db.Decimal(14, 4)
  unit             String    @default("pcs")
  unitPrice        Decimal   @map("unit_price") @db.Decimal(14, 2)
  totalPrice       Decimal   @map("total_price") @db.Decimal(14, 2)
  currency         String    @default("USD")
  requisitionLineId String?  @map("requisition_line_id")
  quoteLineId      String?   @map("quote_line_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  hlc              String?
  deletedAt        DateTime? @map("deleted_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  vessel           Vessel           @relation(fields: [vesselId], references: [id])
  po               PurchaseOrder    @relation(fields: [poId], references: [id])
  part             Part?            @relation(fields: [partId], references: [id])
  requisitionLine  RequisitionLine? @relation(fields: [requisitionLineId], references: [id])
  receiptLines     GoodsReceiptLine[]

  @@index([tenantId, vesselId, poId])
  @@map("po_lines")
}

// GoodsReceipt — a delivery event against a PurchaseOrder.
model GoodsReceipt {
  id              String    @id
  tenantId        String    @map("tenant_id")
  vesselId        String    @map("vessel_id")
  poId            String    @map("po_id")
  receivedByUserId String?  @map("received_by_user_id")
  receivedAt      DateTime  @map("received_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  vessel Vessel             @relation(fields: [vesselId], references: [id])
  po     PurchaseOrder      @relation(fields: [poId], references: [id])
  lines  GoodsReceiptLine[]

  @@index([tenantId, vesselId, poId])
  @@map("goods_receipts")
}

// GoodsReceiptLine — per-line received quantities (supports partial receipts).
model GoodsReceiptLine {
  id               String    @id
  tenantId         String    @map("tenant_id")
  vesselId         String    @map("vessel_id")
  receiptId        String    @map("receipt_id")
  poLineId         String    @map("po_line_id")
  partId           String?   @map("part_id")
  description      String?
  quantityOrdered  Decimal   @map("quantity_ordered") @db.Decimal(14, 4)
  quantityReceived Decimal   @map("quantity_received") @db.Decimal(14, 4)
  unit             String    @default("pcs")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  hlc              String?
  deletedAt        DateTime? @map("deleted_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  vessel  Vessel       @relation(fields: [vesselId], references: [id])
  receipt GoodsReceipt @relation(fields: [receiptId], references: [id])
  poLine  POLine       @relation(fields: [poLineId], references: [id])
  part    Part?        @relation(fields: [partId], references: [id])

  @@index([tenantId, vesselId, receiptId])
  @@index([tenantId, vesselId, poLineId])
  @@map("goods_receipt_lines")
}

// ── Certificates (P2-1) ──────────────────────────────────────────────────────
// Polymorphic: a Certificate can belong to a vessel, a component, or a crew
// member. The subject is identified by subjectType + subjectId (soft FK).
// CertificateType is the tenant-scoped catalog entry (fleet-wide, like Part).
// Certificate and CertificateAttachment are vessel-scoped and sync-aware.

model CertificateType {
  id          String  @id
  tenantId    String  @map("tenant_id")
  name        String
  description String?
  /// JSON: [90, 60, 30, 7] — days before expiry to alert
  alertDaysJson String? @map("alert_days_json")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  certificates Certificate[]

  @@index([tenantId])
  @@map("certificate_types")
}

model Certificate {
  id                String                 @id
  tenantId          String                 @map("tenant_id")
  vesselId          String?                @map("vessel_id")
  certificateTypeId String                 @map("certificate_type_id")
  subjectType       CertificateSubjectType @map("subject_type")
  subjectId         String                 @map("subject_id")
  number            String?
  issuedAt          DateTime?              @map("issued_at")
  expiresAt         DateTime?              @map("expires_at")
  issuedBy          String?                @map("issued_by")
  notes             String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  vessel          Vessel?                 @relation(fields: [vesselId], references: [id])
  certificateType CertificateType         @relation(fields: [certificateTypeId], references: [id])
  attachments     CertificateAttachment[]

  @@index([tenantId, vesselId])
  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, expiresAt])
  @@map("certificates")
}

model CertificateAttachment {
  id            String @id
  tenantId      String @map("tenant_id")
  vesselId      String? @map("vessel_id")
  certificateId String @map("certificate_id")
  fileName      String @map("file_name")
  storageKey    String @map("storage_key")
  mimeType      String? @map("mime_type")
  sizeBytes     Int?    @map("size_bytes")

  uploadedAt DateTime  @default(now()) @map("uploaded_at")
  hlc        String?
  deletedAt  DateTime? @map("deleted_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  vessel      Vessel?     @relation(fields: [vesselId], references: [id])
  certificate Certificate @relation(fields: [certificateId], references: [id])

  @@index([tenantId, certificateId])
  @@map("certificate_attachments")
}

// ── Notifications (P2-1, shore-only) ────────────────────────────────────────
// In-app alert records. Created by the expiry-check job when a Certificate
// is approaching its expiresAt date. Not sync-aware (shore read-only).

model Notification {
  id       String           @id
  tenantId String           @map("tenant_id")
  vesselId String?          @map("vessel_id")
  type     NotificationType
  title    String
  message  String
  refId    String?          @map("ref_id")
  readAt   DateTime?        @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, readAt])
  @@index([tenantId, type, refId])
  @@map("notifications")
}

// ── Safety (P2-2) ─────────────────────────────────────────────────────────────
// DrillType is tenant-scoped (fleet-wide catalog). Drill, DrillRecord,
// WorkPermit, and PermitApproval are vessel-scoped and sync-aware.
// PermitTemplate is tenant-scoped (checklist definitions per permit type).
// CHECK: HOT_WORK permit cannot be ACTIVE without risk_assessment_json — enforced
// at application layer + DB constraint added in migration.

model DrillType {
  id          String    @id
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  drills Drill[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("drill_types")
}

model Drill {
  id              String      @id
  tenantId        String      @map("tenant_id")
  vesselId        String      @map("vessel_id")
  drillTypeId     String      @map("drill_type_id")
  status          DrillStatus @default(SCHEDULED)
  scheduledAt     DateTime    @map("scheduled_at")
  conductedAt     DateTime?   @map("conducted_at")
  durationMinutes Int?        @map("duration_minutes")
  location        String?
  leadOfficer     String?     @map("lead_officer")
  notes           String?
  reportKey       String?     @map("report_key")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime?   @map("deleted_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  vessel    Vessel        @relation(fields: [vesselId], references: [id])
  drillType DrillType     @relation(fields: [drillTypeId], references: [id])
  records   DrillRecord[]

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, scheduledAt])
  @@map("drills")
}

model DrillRecord {
  id              String    @id
  tenantId        String    @map("tenant_id")
  vesselId        String    @map("vessel_id")
  drillId         String    @map("drill_id")
  participantName String    @map("participant_name")
  role            String?
  signedAt        DateTime? @map("signed_at")
  signatureHash   String?   @map("signature_hash")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vessel Vessel @relation(fields: [vesselId], references: [id])
  drill  Drill  @relation(fields: [drillId], references: [id])

  @@index([tenantId, vesselId, drillId])
  @@map("drill_records")
}

// PermitTemplate — tenant-scoped checklist catalog per permit type.
// checklistItemsJson: JSON [{id, description, required}]
model PermitTemplate {
  id                 String         @id
  tenantId           String         @map("tenant_id")
  permitType         WorkPermitType @map("permit_type")
  name               String
  checklistItemsJson String?        @map("checklist_items_json")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  permits WorkPermit[]

  @@index([tenantId])
  @@map("permit_templates")
}

// WorkPermit — vessel-scoped, sync-aware.
// riskAssessmentJson: [{itemId, description, checked}]
// gasTestJson: [{time, testedBy, o2Pct, lelPct, h2sPpm}]
// hazardsJson: [{hazard, controls}]
model WorkPermit {
  id                String           @id
  tenantId          String           @map("tenant_id")
  vesselId          String           @map("vessel_id")
  permitType        WorkPermitType   @map("permit_type")
  templateId        String?          @map("template_id")
  status            WorkPermitStatus @default(REQUESTED)
  title             String
  location          String?
  workDescription   String?          @map("work_description")
  requestedByUserId String?          @map("requested_by_user_id")
  validFrom         DateTime?        @map("valid_from")
  validUntil        DateTime?        @map("valid_until")
  closedAt          DateTime?        @map("closed_at")
  riskAssessmentJson String?         @map("risk_assessment_json")
  gasTestJson       String?          @map("gas_test_json")
  hazardsJson       String?          @map("hazards_json")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  hlc               String?
  deletedAt         DateTime?        @map("deleted_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  vessel    Vessel          @relation(fields: [vesselId], references: [id])
  template  PermitTemplate? @relation(fields: [templateId], references: [id])
  approvals PermitApproval[]

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, permitType])
  @@map("work_permits")
}

// PermitApproval — sign-off record on a WorkPermit.
model PermitApproval {
  id            String    @id
  tenantId      String    @map("tenant_id")
  vesselId      String    @map("vessel_id")
  permitId      String    @map("permit_id")
  approvedBy    String    @map("approved_by")
  role          String
  approvedAt    DateTime  @map("approved_at")
  signatureHash String?   @map("signature_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  hlc           String?
  deletedAt     DateTime? @map("deleted_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  vessel Vessel     @relation(fields: [vesselId], references: [id])
  permit WorkPermit @relation(fields: [permitId], references: [id])

  @@index([tenantId, vesselId, permitId])
  @@map("permit_approvals")
}

// ── QHSE (P2-3) ──────────────────────────────────────────────────────────────
// QhseDocument + DocumentRevision: tenant-scoped document control. Replacing a
//   controlled document adds a new DocumentRevision row; old revisions stay.
// ChecklistTemplate: tenant-scoped reusable checklist definition.
// ChecklistInstance: vessel-scoped, sync-aware. responsesJson stores per-item
//   signature: [{itemId, text, checked, signatureKey?, signedByUserId?, signedAt?}]
// Finding: vessel-scoped, sync-aware (NEAR_MISS / NC / OBSERVATION / HAZARD).
// Capa: vessel-scoped, sync-aware, with ownerUserId + dueDate.

enum FindingKind {
  NEAR_MISS
  NON_CONFORMANCE
  OBSERVATION
  HAZARD
}

enum FindingStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  VERIFIED
  CLOSED
}

enum ChecklistInstanceStatus {
  IN_PROGRESS
  COMPLETED
}

model QhseDocument {
  id                String    @id
  tenantId          String    @map("tenant_id")
  title             String
  category          String?
  description       String?
  isControlled      Boolean   @default(false) @map("is_controlled")
  currentRevisionId String?   @map("current_revision_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  hlc               String?
  deletedAt         DateTime? @map("deleted_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  revisions DocumentRevision[]

  @@index([tenantId])
  @@map("qhse_documents")
}

model DocumentRevision {
  id               String    @id
  tenantId         String    @map("tenant_id")
  documentId       String    @map("document_id")
  revisionNumber   Int       @map("revision_number")
  summary          String?
  s3Key            String    @map("s3_key")
  authoredByUserId String?   @map("authored_by_user_id")
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  hlc              String?
  deletedAt        DateTime? @map("deleted_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  document QhseDocument @relation(fields: [documentId], references: [id])

  @@unique([documentId, revisionNumber])
  @@index([tenantId, documentId])
  @@map("document_revisions")
}

model ChecklistTemplate {
  id          String    @id
  tenantId    String    @map("tenant_id")
  title       String
  description String?
  /// JSON: [{id, text, required}]
  itemsJson   String    @map("items_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  instances ChecklistInstance[]

  @@index([tenantId])
  @@map("checklist_templates")
}

model ChecklistInstance {
  id            String                  @id
  tenantId      String                  @map("tenant_id")
  vesselId      String                  @map("vessel_id")
  templateId    String?                 @map("template_id")
  title         String
  status        ChecklistInstanceStatus @default(IN_PROGRESS)
  /// JSON: [{itemId, text, checked, signatureKey?, signedByUserId?, signedAt?}]
  responsesJson String                  @map("responses_json")
  completedAt   DateTime?               @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  hlc           String?
  deletedAt     DateTime? @map("deleted_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  vessel   Vessel             @relation(fields: [vesselId], references: [id])
  template ChecklistTemplate? @relation(fields: [templateId], references: [id])

  @@index([tenantId, vesselId, status])
  @@map("checklist_instances")
}

model Finding {
  id             String        @id
  tenantId       String        @map("tenant_id")
  vesselId       String        @map("vessel_id")
  kind           FindingKind
  status         FindingStatus @default(OPEN)
  title          String
  description    String?
  raisedByUserId String?       @map("raised_by_user_id")
  raisedAt       DateTime      @map("raised_at")
  closedAt       DateTime?     @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  hlc            String?
  deletedAt      DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vessel Vessel @relation(fields: [vesselId], references: [id])
  capas  Capa[]

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, kind])
  @@map("findings")
}

model Capa {
  id          String     @id
  tenantId    String     @map("tenant_id")
  vesselId    String     @map("vessel_id")
  findingId   String?    @map("finding_id")
  type        String
  description String
  ownerUserId String?    @map("owner_user_id")
  dueDate     DateTime?  @map("due_date")
  status      CapaStatus @default(OPEN)
  verifiedAt  DateTime?  @map("verified_at")
  closedAt    DateTime?  @map("closed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  vessel  Vessel   @relation(fields: [vesselId], references: [id])
  finding Finding? @relation(fields: [findingId], references: [id])

  @@index([tenantId, vesselId, status])
  @@index([tenantId, vesselId, findingId])
  @@map("capas")
}

// ── Crewing (P2-4) ────────────────────────────────────────────────────────────
// All four entities are vessel-scoped and sync-aware.
// RestHourEntry.mlcValid reflects MLC 2006 Regulation VIII/1 validation run at
// save time — daily ≥10h rest AND weekly ≥77h rest. A save that would violate
// MLC is rejected with 400 + violation details (enforced at application layer).

enum CrewMemberStatus {
  ACTIVE
  ON_LEAVE
  SIGNED_OFF
}

enum RotationStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model CrewMember {
  id          String           @id
  tenantId    String           @map("tenant_id")
  vesselId    String           @map("vessel_id")
  firstName   String           @map("first_name")
  lastName    String           @map("last_name")
  rank        String
  nationality String?
  dateOfBirth DateTime?        @map("date_of_birth")
  email       String?
  phone       String?
  status      CrewMemberStatus @default(ACTIVE)
  signOnDate  DateTime?        @map("sign_on_date")
  signOffDate DateTime?        @map("sign_off_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  hlc         String?
  deletedAt   DateTime? @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  vessel          Vessel          @relation(fields: [vesselId], references: [id])
  rotations       Rotation[]
  restHourEntries RestHourEntry[]
  crewCertificates CrewCertificate[]

  @@index([tenantId, vesselId])
  @@index([tenantId, vesselId, status])
  @@map("crew_members")
}

model Rotation {
  id             String         @id
  tenantId       String         @map("tenant_id")
  vesselId       String         @map("vessel_id")
  crewMemberId   String         @map("crew_member_id")
  plannedSignOn  DateTime       @map("planned_sign_on")
  plannedSignOff DateTime       @map("planned_sign_off")
  actualSignOn   DateTime?      @map("actual_sign_on")
  actualSignOff  DateTime?      @map("actual_sign_off")
  status         RotationStatus @default(PLANNED)
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  hlc            String?
  deletedAt      DateTime? @map("deleted_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id])

  @@index([tenantId, vesselId, crewMemberId])
  @@index([tenantId, vesselId, status])
  @@map("rotations")
}

model RestHourEntry {
  id              String    @id
  tenantId        String    @map("tenant_id")
  vesselId        String    @map("vessel_id")
  crewMemberId    String    @map("crew_member_id")
  date            String    @map("date")
  /// JSON: 24 booleans; index = hour of day (0=00:00, 23=23:00); true = worked
  hoursWorkedJson String    @map("hours_worked_json")
  mlcValid        Boolean   @default(true) @map("mlc_valid")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id])

  @@unique([tenantId, vesselId, crewMemberId, date])
  @@index([tenantId, vesselId, crewMemberId])
  @@map("rest_hour_entries")
}

model CrewCertificate {
  id              String    @id
  tenantId        String    @map("tenant_id")
  vesselId        String    @map("vessel_id")
  crewMemberId    String    @map("crew_member_id")
  certificateType String    @map("certificate_type")
  number          String?
  issuedAt        DateTime? @map("issued_at")
  expiresAt       DateTime? @map("expires_at")
  issuedBy        String?   @map("issued_by")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  hlc             String?
  deletedAt       DateTime? @map("deleted_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id])

  @@index([tenantId, vesselId, crewMemberId])
  @@index([tenantId, expiresAt])
  @@map("crew_certificates")
}

// ── Sync engine tables ───────────────────────────────────────────────────────
// One Outbox + one SyncRecord per (tenant, vessel) namespace. The shore runs
// one SyncEngine per pair (ADR 0002 §9). Both tables carry tenantId + vesselId
// so the per-engine adapter scopes its reads/writes.

model Outbox {
  id         String    @id
  tenantId   String    @map("tenant_id")
  vesselId   String    @map("vessel_id")
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  operation  String
  payload    Json?
  hlc        String
  nodeId     String    @map("node_id")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, vesselId, sentAt, createdAt], name: "outbox_pending_idx")
  @@map("outbox")
}

model SyncRecord {
  tenantId   String    @map("tenant_id")
  vesselId   String    @map("vessel_id")
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  hlc        String
  deletedAt  DateTime? @map("deleted_at")
  fields     Json

  @@id([tenantId, vesselId, entityType, entityId])
  @@map("sync_records")
}
