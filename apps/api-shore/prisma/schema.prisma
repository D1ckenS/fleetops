generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN   // platform-level; not tenant-scoped
  TENANT_ADMIN
  PURCHASE_MANAGER
  MASTER        // Captain
  CHIEF_ENGINEER
  OFFICER
  CREW
}

// ── Tenant ───────────────────────────────────────────────────────────────────
// Root aggregate. Not sync-aware (shore-only master record).

model Tenant {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  vessels Vessel[]
  users   User[]

  @@map("tenants")
}

// ── Vessel ───────────────────────────────────────────────────────────────────
// Tenant-scoped. RLS applied in migration. Sync-aware (hlc + deletedAt).

model Vessel {
  id        String    @id
  tenantId  String    @map("tenant_id")
  name      String
  imoNumber String?   @map("imo_number")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  hlc       String?
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  users  User[]

  @@map("vessels")
}

// ── User ─────────────────────────────────────────────────────────────────────
// Tenant-scoped. passwordHash is nullable for OIDC-only users (P0-10).

model User {
  id           String    @id
  tenantId     String    @map("tenant_id")
  vesselId     String?   @map("vessel_id")
  email        String
  passwordHash String?   @map("password_hash")
  role         Role      @default(OFFICER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  hlc          String?
  deletedAt    DateTime? @map("deleted_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  vessel Vessel? @relation(fields: [vesselId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

// ── Sync engine tables ───────────────────────────────────────────────────────
// One Outbox + one SyncRecord per (tenant, vessel) namespace. The shore runs
// one SyncEngine per pair (ADR 0002 §9). Both tables carry tenantId + vesselId
// so the per-engine adapter scopes its reads/writes.

model Outbox {
  id         String    @id
  tenantId   String    @map("tenant_id")
  vesselId   String    @map("vessel_id")
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  operation  String
  payload    Json?
  hlc        String
  nodeId     String    @map("node_id")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, vesselId, sentAt, createdAt], name: "outbox_pending_idx")
  @@map("outbox")
}

model SyncRecord {
  tenantId   String    @map("tenant_id")
  vesselId   String    @map("vessel_id")
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  hlc        String
  deletedAt  DateTime? @map("deleted_at")
  fields     Json

  @@id([tenantId, vesselId, entityType, entityId])
  @@map("sync_records")
}
