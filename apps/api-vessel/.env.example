# ─────────────────────────────────────────────────────────────────────────────
# FleetOps — Vessel API environment variables
# Copy this file to .env and fill in every value marked <REQUIRED>.
# On the vessel workstation this file lives next to vessel.db in the app's
# data directory (C:\ProgramData\FleetOps\ on Windows).
# NEVER commit a file that contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Path to the SQLite database file.  Relative paths resolve from the process
# working directory; prefer absolute paths in production.
# Dev default (file created in apps/api-vessel/):
DATABASE_URL=./vessel.db
# Production example (Windows):
# DATABASE_URL=C:\ProgramData\FleetOps\vessel.db

# ── JWT — shore-issued RS256 public key ───────────────────────────────────────
# Copy jwt-public.pem from the shore server to the vessel at provisioning time.
# The vessel uses this to verify shore-issued tokens without a network call.
# Generate the keypair on shore with:  pnpm -w run gen:jwt-keys
JWT_PUBLIC_KEY_PATH=../../keys/jwt-public.pem
# Production example (Windows):
# JWT_PUBLIC_KEY_PATH=C:\ProgramData\FleetOps\keys\jwt-public.pem

# ── Vessel-local authentication (offline / dev) ───────────────────────────────
# Used only for the local password-login path (POST /auth/login on the vessel).
# Must be different for every vessel — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VESSEL_LOCAL_JWT_SECRET=vessel-local-dev-secret-change-me
VESSEL_LOCAL_JWT_TTL_MS=28800000   # 8 h

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development              # set to "production" in the Electron bundle

# ── S3-compatible photo storage ───────────────────────────────────────────────
# Point at the same MinIO/S3 instance as the shore server so that photos
# uploaded on the vessel are immediately visible on shore.
# If the vessel has no internet, uploads queue and are retried on reconnect
# (note: S3 retry is handled by the AWS SDK, not the FleetOps outbox).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=fleetops_minio
S3_SECRET_ACCESS_KEY=fleetops_minio_dev
S3_BUCKET=fleetops-photos
S3_FORCE_PATH_STYLE=1
S3_REGION=us-east-1
# Production — point at the shore server's MinIO:
# S3_ENDPOINT=http://<SHORE_PUBLIC_IP>:9000

# ── gRPC Sync client ──────────────────────────────────────────────────────────
# Set SYNC_ENABLED=1 to connect to the shore gRPC gateway.
# SYNC_TENANT_ID and SYNC_VESSEL_ID are obtained from the seed output
# (pnpm run seed on shore) or from POST /tenants + POST /vessels.
SYNC_ENABLED=0
# SYNC_ENABLED=1

# The tenant this vessel belongs to (ULID from shore seed output):
# SYNC_TENANT_ID=<REQUIRED when SYNC_ENABLED=1>

# The vessel ID assigned on shore (ULID from shore seed output):
# SYNC_VESSEL_ID=<REQUIRED when SYNC_ENABLED=1>

# Address of the shore gRPC sync gateway (host:port, no http:// prefix):
SHORE_SYNC_URL=localhost:50051
# Production example:
# SHORE_SYNC_URL=<SHORE_PUBLIC_IP>:50051

# Shared secret passed in gRPC metadata. Set to any strong random string;
# must match whatever the shore gateway expects (dev mode accepts any non-empty value).
# SYNC_AUTH_TOKEN=<REQUIRED when SYNC_ENABLED=1>

# How often (ms) the vessel drains its outbox and pushes changes to shore.
SYNC_DRAIN_INTERVAL_MS=5000

# [optional] Override the path to sync.proto (defaults to packages/proto/sync.proto
# relative to the compiled main.js — only needed if the packaged path differs):
# SYNC_PROTO_PATH=/absolute/path/to/sync.proto
